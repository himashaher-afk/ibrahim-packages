            <a id="instapay-link-btn" href="#" target="_blank" onclick="event.stopPropagation();openInstapayLink(event);" style="display:flex;align-items:center;justify-content:center;gap:6px;margin-top:6px;background:linear-gradient(135deg,#6366F1,#8B5CF6);color:#fff;border-radius:12px;padding:10px 14px;font-size:0.85rem;font-weight:900;text-decoration:none;text-align:center;width:100%;box-sizing:border-box;">
