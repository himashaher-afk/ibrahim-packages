`<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>احجز باقتك مع إبراهيم كينج الباقات</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Tajawal:wght@300;400;700;900&display=swap" rel="stylesheet">
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-app.js";
import { getFirestore, collection, addDoc, doc, getDoc } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js";
const firebaseConfig = {
  apiKey: "AIzaSyAEWadq4RixEuUrDBK_DhIBS4JeOBM7DUc",
  authDomain: "my-orders-e07e8.firebaseapp.com",
  projectId: "my-orders-e07e8",
  storageBucket: "my-orders-e07e8.firebasestorage.app",
  messagingSenderId: "368034193396",
  appId: "1:368034193396:web:ea8da759d90c2b3d72e3a1"
};
const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
window._db = db;
window._col = (n) => collection(db, n);
window._addDoc = addDoc;
// ═══ PAGE LOCK CHECK ═══
(async function checkPageActive(){
  try {
    const snap = await getDoc(doc(db,'config','client_page'));
    if(snap.exists()){
      const data = snap.data();
      if(data.active === false){
        document.getElementById('page-lock').style.display='flex';
        document.getElementById('main-content').style.display='none';
      }
    }
  } catch(e){ /* لو مفيش نت — يكمل عادي */ }
})();
// تحميل الباقات
async function loadPackagesFromFirebase(){
  try {
    const {getDocs,collection} = await import("https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js");
    const snap = await getDocs(collection(db,'packages'));
    snap.forEach(d=>{
      const p=d.data();
      if(p.status==='active' && PACKAGES[p.network]){
        PACKAGES[p.network].push(p);
      }
    });
    packagesLoaded=true;
  } catch(e){ console.error(e); }
}
loadPackagesFromFirebase();
// تحميل لينك InstaPay
async function loadInstapayLink(){
  try {
    const {getDoc,doc} = await import('https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js');
    const snap = await getDoc(doc(db,'config','instapayLink'));
    if(snap.exists()){
      const link = snap.data().url || '';
      if(link){
        const btn = document.getElementById('instapay-link-btn');
        const wrap = document.getElementById('instapay-link-wrap');
        if(btn) btn.href = link;
        if(wrap) wrap.style.display = 'block';
        window._instapayLink = link;
      }
    }
  } catch(e){ console.warn('instapay link:',e); }
}
loadInstapayLink();
window.dispatchEvent(new Event('firebase-ready'));
</script>
<style>
:root{--orange:#FF6B00;--we:#9B27AF;--vodafone:#E3000F;--etisalat:#00A550;--bg:#F5F7FF;--card:#FFFFFF;--text:#1A1A2E;--muted:#6B7280;--radius:20px;--shadow:0 4px 30px rgba(0,0,0,0.08);}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;direction:rtl;}
.hero{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 40%,#0f3460 70%,#533483 100%);padding:40px 20px 80px;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(255,107,0,0.15) 0%,transparent 60%),radial-gradient(ellipse at 70% 20%,rgba(83,52,131,0.3) 0%,transparent 50%);z-index:1;}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.1) 0%,rgba(0,0,0,0.4) 100%);z-index:1;}
.hero-content{position:relative;z-index:2;}
.hero-badge{display:inline-block;background:rgba(255,107,0,0.2);border:1px solid rgba(255,107,0,0.4);color:#FF8C42;padding:6px 18px;border-radius:50px;font-size:0.78rem;font-weight:700;margin-bottom:16px;letter-spacing:1px;}
.hero h1{font-family:'Tajawal',sans-serif;font-size:clamp(1.6rem,5vw,2.8rem);font-weight:900;color:#fff;line-height:1.25;margin-bottom:6px;}
.hero h1 span{background:linear-gradient(90deg,#FF6B00,#FFD700);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hero-sub{color:rgba(255,255,255,0.7);font-size:0.88rem;margin-top:10px;}
.hero-features{display:flex;justify-content:center;gap:10px;margin-top:14px;flex-wrap:wrap;}
.hero-feat{background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);backdrop-filter:blur(4px);color:#fff;padding:7px 16px;border-radius:50px;font-size:0.8rem;font-weight:700;}
.steps-bar{display:flex;justify-content:center;gap:0;background:#fff;border-bottom:1px solid #E5E7EB;padding:14px 20px;position:sticky;top:0;z-index:50;box-shadow:0 2px 12px rgba(0,0,0,0.06);overflow-x:auto;}
.step{display:flex;align-items:center;gap:7px;padding:7px 14px;border-radius:50px;font-size:0.8rem;font-weight:700;color:#9CA3AF;white-space:nowrap;transition:all .3s;}
.step.active{background:linear-gradient(135deg,#FF6B00,#FF8C42);color:#fff;}
.step.done{color:#10B981;}
.step-num{width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:900;}
.step.active .step-num{background:rgba(255,255,255,0.25);}
.step-arrow{color:#D1D5DB;font-size:0.8rem;padding:0 4px;}
.container{max-width:680px;margin:0 auto;padding:0 16px 80px;}
.section-card{background:rgba(255,255,255,0.92);backdrop-filter:blur(8px);border-radius:var(--radius);box-shadow:var(--shadow);padding:24px;margin-top:-40px;margin-bottom:16px;}
.section-title{font-size:1.05rem;font-weight:900;margin-bottom:16px;display:flex;align-items:center;gap:8px;color:#111;border-bottom:2px solid #F3F4F6;padding-bottom:12px;}
.networks-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
.net-card{border:none;border-radius:18px;padding:18px 10px 14px;text-align:center;cursor:pointer;transition:transform .25s,box-shadow .25s;position:relative;overflow:hidden;box-shadow:0 4px 14px rgba(0,0,0,0.15);}
.net-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,0.2);}
.net-card.orange-card,.net-card.selected-orange{background:linear-gradient(145deg,#FF6B00,#FF9A3C);}
.net-card.we-card,.net-card.selected-we{background:linear-gradient(145deg,#7B1FA2,#AB47BC);}
.net-card.vodafone-card,.net-card.selected-vodafone{background:linear-gradient(145deg,#C62828,#E57373);}
.net-card.vfbiz-card,.net-card.selected-vodafone_business{background:linear-gradient(145deg,#6D0000,#C62828);}
.net-card.etisalat-card,.net-card.selected-etisalat{background:linear-gradient(145deg,#1B5E20,#43A047);}
.net-card.selected-orange{box-shadow:0 0 0 3px #FF6B00,0 8px 24px rgba(255,107,0,0.4);}
.net-card.selected-we{box-shadow:0 0 0 3px #9B27AF,0 8px 24px rgba(155,39,175,0.4);}
.net-card.selected-vodafone{box-shadow:0 0 0 3px #E3000F,0 8px 24px rgba(227,0,15,0.4);}
.net-card.selected-vodafone_business{box-shadow:0 0 0 3px #8B0000,0 8px 24px rgba(139,0,0,0.4);}
.net-card.selected-etisalat{box-shadow:0 0 0 3px #00A550,0 8px 24px rgba(0,165,80,0.4);}
.net-icon{font-size:2.2rem;margin-bottom:6px;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));}
.net-name{font-weight:800;font-size:0.9rem;color:#fff;text-shadow:0 1px 3px rgba(0,0,0,0.3);}
.net-sub{font-size:0.65rem;color:rgba(255,255,255,0.8);margin-top:2px;}
.check-badge{position:absolute;top:8px;left:8px;width:20px;height:20px;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:0.65rem;color:#fff;background:rgba(255,255,255,0.3);border:2px solid rgba(255,255,255,0.8);}
.net-card.selected-orange .check-badge{display:flex;}
.net-card.selected-we .check-badge{display:flex;}
.net-card.selected-vodafone .check-badge{display:flex;}
.net-card.selected-vodafone_business .check-badge{display:flex;}
.net-card.selected-etisalat .check-badge{display:flex;}
.info-btn{position:absolute;top:7px;right:7px;height:20px;padding:0 6px;border-radius:20px;background:rgba(255,255,255,0.25);border:none;font-size:0.65rem;cursor:pointer;display:flex;align-items:center;gap:2px;color:#fff;z-index:2;transition:all .2s;white-space:nowrap;font-weight:700;}
.info-btn:hover{background:rgba(255,255,255,0.4);}
.cond-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:flex-end;justify-content:center;}
.cond-modal.show{display:flex;}
.cond-box{background:#fff;border-radius:24px 24px 0 0;padding:24px;width:100%;max-width:680px;max-height:80vh;overflow-y:auto;}
.cond-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.cond-title{font-size:1.05rem;font-weight:800;}
.cond-close{background:none;border:none;font-size:1.4rem;cursor:pointer;color:#6B7280;}
.cond-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;}
.cond-list li{display:flex;align-items:flex-start;gap:10px;font-size:0.88rem;line-height:1.5;color:#374151;}
.cond-list li::before{content:"✓";width:20px;height:20px;border-radius:50%;background:#10B981;color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:900;flex-shrink:0;margin-top:1px;}
.cond-list li.warn::before{content:"⚠";background:#F59E0B;}
.cond-list li.info::before{content:"ℹ";background:#3B82F6;}
.pkgs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.pkg-card{border:2px solid #E5E7EB;border-radius:18px;cursor:pointer;transition:all .25s;position:relative;overflow:hidden;display:flex;flex-direction:column;}
.pkg-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,0.12);}
.pkg-card.selected{border-color:var(--accent,#FF6B00);background:rgba(var(--accent-rgb,255,107,0),0.05);}
.pkg-card.selected .pkg-check{display:flex;}
.pkg-header{background:linear-gradient(135deg,var(--accent,#FF6B00),var(--accent2,#FFD700));padding:12px 14px;text-align:center;}
.pkg-name-title{font-family:'Tajawal',sans-serif;font-size:1rem;font-weight:900;color:#fff;text-shadow:0 1px 4px rgba(0,0,0,0.25);}
.pkg-main-row{display:flex;align-items:center;justify-content:center;gap:12px;padding:14px 12px 8px;border-bottom:1px solid #F3F4F6;}
.pkg-stat{text-align:center;flex:1;}
.pkg-info-block{padding:10px 14px 14px;border-top:1px solid #F3F4F6;display:flex;flex-direction:column;gap:2px;}
.pkg-info-lbl{font-size:0.72rem;color:var(--muted);font-weight:700;}
.pkg-info-val{font-size:0.88rem;font-weight:800;color:#1A1A2E;direction:ltr;text-align:right;padding-right:4px;}
.pkg-stat-val{font-family:'Tajawal',sans-serif;font-size:2.2rem;font-weight:900;line-height:1;color:var(--accent,#FF6B00);}
.pkg-stat-lbl{font-size:0.68rem;color:var(--muted);font-weight:700;margin-top:2px;}
.pkg-divider{width:1px;height:48px;background:#E5E7EB;flex-shrink:0;}
.pkg-price-row{padding:10px 14px;text-align:center;}
.pkg-price{font-family:'Tajawal',sans-serif;font-size:1.7rem;font-weight:900;background:linear-gradient(135deg,var(--accent,#FF6B00),var(--accent2,#FFD700));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.pkg-price-lbl{font-size:0.7rem;color:var(--muted);margin-top:2px;}
.pkg-note{margin:0 14px 12px;background:rgba(255,107,0,0.06);border:1px solid rgba(255,107,0,0.15);border-radius:10px;padding:7px 10px;font-size:0.72rem;color:#92400E;line-height:1.5;display:flex;gap:5px;align-items:flex-start;}
.pkg-note-icon{flex-shrink:0;margin-top:1px;}
.pkg-badge{position:absolute;top:-8px;right:12px;background:linear-gradient(135deg,#FF6B00,#FFD700);color:#fff;font-size:0.58rem;font-weight:700;padding:3px 8px;border-radius:20px;}
.pkg-check{position:absolute;top:8px;left:8px;width:20px;height:20px;border-radius:50%;background:var(--accent,#FF6B00);display:none;align-items:center;justify-content:center;font-size:0.65rem;color:#fff;}
.pay-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.pay-card{border:2px solid #E5E7EB;border-radius:16px;padding:18px 12px;cursor:pointer;transition:all .25s;display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center;position:relative;}
.pay-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,0.1);}
.pay-card.selected{border-color:#6366F1;background:rgba(99,102,241,0.06);}
.pay-card.selected .pay-check{display:flex;}
.pay-icon{font-size:2.2rem;}
.pay-name{font-size:0.88rem;font-weight:700;color:var(--text);}
.pay-sub{font-size:0.7rem;color:var(--muted);}
.pay-num-box{display:none;background:#F0F0FF;border:1px solid rgba(99,102,241,0.3);border-radius:10px;padding:6px 10px;font-size:0.8rem;font-weight:700;color:#4F46E5;direction:ltr;cursor:pointer;align-items:center;gap:6px;width:100%;justify-content:center;margin-top:4px;transition:background .2s;}
.pay-num-box:hover{background:#E0E0FF;}
.pay-num-box.visible{display:flex;}
.pay-check{display:none;width:22px;height:22px;border-radius:50%;flex-shrink:0;background:#6366F1;color:#fff;font-size:0.7rem;align-items:center;justify-content:center;position:absolute;top:8px;left:8px;}
.copy-hint{font-size:0.62rem;color:#9CA3AF;}
.form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:12px;}
.form-group label{font-size:0.82rem;font-weight:700;color:var(--text);}
.form-group input,.form-group textarea{background:#F9FAFB;border:1.5px solid #E5E7EB;border-radius:12px;color:var(--text);font-family:'Cairo',sans-serif;font-size:0.9rem;padding:12px 14px;outline:none;transition:border-color .2s;direction:rtl;width:100%;}
.form-group input:focus,.form-group textarea:focus{border-color:#FF6B00;background:#fff;}
.form-group textarea{min-height:80px;resize:none;}
.input-icon-wrap{position:relative;}
.input-icon-wrap input{padding-right:42px;}
.input-icon{position:absolute;right:13px;top:50%;transform:translateY(-50%);font-size:1rem;}
.upload-area{border:2px dashed #D1D5DB;border-radius:14px;padding:24px 16px;text-align:center;cursor:pointer;transition:all .25s;background:#FAFAFA;}
.upload-area:hover,.upload-area.drag{border-color:#FF6B00;background:rgba(255,107,0,0.04);}
.upload-icon{font-size:2.2rem;margin-bottom:6px;}
.upload-lbl{font-size:0.85rem;font-weight:600;}
.upload-sub{font-size:0.73rem;color:var(--muted);margin-top:3px;}
.upload-preview{margin-top:12px;display:none;border-radius:12px;overflow:hidden;border:1.5px solid #E5E7EB;}
.upload-preview img{width:100%;display:block;max-height:200px;object-fit:cover;}
#receipt-input{display:none;}
.summary-box{background:linear-gradient(135deg,#1A1A2E,#16213E);border-radius:var(--radius);padding:22px;color:#fff;margin-bottom:16px;}
.summary-box h3{font-size:0.92rem;font-weight:700;margin-bottom:14px;color:rgba(255,255,255,0.65);}
.summary-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-size:0.86rem;}
.summary-row:last-child{border:none;padding-top:10px;}
.summary-row .val{font-weight:700;}
.summary-total .val{font-size:1.2rem;color:#FFD700;}
.submit-btn{width:100%;padding:15px;border:none;border-radius:var(--radius);cursor:pointer;font-family:'Cairo',sans-serif;font-size:1rem;font-weight:700;background:linear-gradient(135deg,#FF6B00,#FF8C42);color:#fff;letter-spacing:.5px;box-shadow:0 4px 20px rgba(255,107,0,0.4);transition:all .25s;}
.submit-btn:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(255,107,0,0.5);}
.submit-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.success-screen{display:none;text-align:center;padding:40px 20px;}
.success-screen.show{display:block;}
.success-icon{width:76px;height:76px;border-radius:50%;background:linear-gradient(135deg,#10B981,#34D399);margin:0 auto 18px;display:flex;align-items:center;justify-content:center;font-size:1.9rem;animation:popIn .5s cubic-bezier(.34,1.56,.64,1);}
@keyframes popIn{from{transform:scale(0)}to{transform:scale(1)}}
.success-screen h2{font-size:1.4rem;font-weight:900;margin-bottom:6px;}
.success-screen p{color:var(--muted);font-size:0.88rem;line-height:1.6;}
.order-id{display:inline-block;background:#F3F4F6;border-radius:10px;padding:7px 18px;margin:14px 0;font-weight:700;font-size:0.88rem;color:#374151;letter-spacing:1px;}
.nav-btns{display:flex;gap:10px;margin-top:14px;}
.btn-back{flex:1;padding:13px;border:2px solid #E5E7EB;border-radius:13px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:0.88rem;font-weight:700;background:#fff;color:var(--text);transition:all .2s;}
.btn-back:hover{background:#F3F4F6;}
.btn-next{flex:2;padding:13px;border:none;border-radius:13px;cursor:pointer;font-family:'Cairo',sans-serif;font-size:0.88rem;font-weight:700;background:linear-gradient(135deg,#FF6B00,#FF8C42);color:#fff;transition:all .2s;}
.btn-next:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(255,107,0,0.4);}
.pane{display:none;animation:fadeUp .35s ease;}
.pane.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse-indigo{0%,100%{box-shadow:0 0 0 0 rgba(99,102,241,0.4)}50%{box-shadow:0 0 0 8px rgba(99,102,241,0)}}
.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(80px);background:#1A1A2E;color:#fff;border-radius:12px;padding:11px 22px;font-size:0.86rem;font-weight:600;z-index:999;transition:transform .3s;box-shadow:0 8px 30px rgba(0,0,0,0.2);white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}
.toast.err{background:#EF4444;}
.toast.ok{background:#10B981;}
.no-pkgs{text-align:center;padding:36px 20px;color:#9CA3AF;font-size:0.9rem;background:#F9FAFB;border-radius:14px;border:2px dashed #E5E7EB;}
.no-pkgs-icon{font-size:2.4rem;margin-bottom:10px;}
.no-pkgs-title{font-weight:700;font-size:0.95rem;color:#6B7280;margin-bottom:4px;}
.no-pkgs-sub{font-size:0.78rem;color:#9CA3AF;}
@media(max-width:480px){.section-card{padding:18px 14px;}.pkgs-grid{grid-template-columns:1fr 1fr;}.pkg-stat-val{font-size:1.6rem;}}
</style>
</head>
<body>
<!-- LOCK SCREEN -->
<div id="page-lock" style="display:none!important;position:fixed;inset:0;background:#070B14;z-index:9999;align-items:center;justify-content:center;flex-direction:column;">
  <div style="text-align:center;padding:40px;max-width:340px;">
    <p style="font-family:'Tajawal',sans-serif;font-size:1.1rem;font-weight:900;color:#FFD700;letter-spacing:2px;margin-bottom:16px;">👑 إبراهيم كينج الباقات 👑</p>
    <div style="font-size:4rem;margin-bottom:16px;">🔒</div>
    <h2 style="font-family:'Tajawal',sans-serif;font-size:1.5rem;font-weight:900;color:#fff;white-space:nowrap;margin-bottom:20px;">⚠️ هذه النسخة غير متاحة ⚠️</h2>
    <p style="line-height:2.2;margin-bottom:28px;">
      <span style="display:block;color:#FF6B00;font-size:1.05rem;font-weight:900;">يوجد إصدار أحدث من الصفحة.</span>
      <span style="display:block;color:#CBD5E1;font-size:0.95rem;font-weight:700;">تواصل مع إبراهيم كينج الباقات للحصول على الرابط الجديد.</span>
    </p>
    <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
  <div style="display:flex;flex-direction:column;align-items:center;animation:bounce 1s infinite;">
    <span style="color:#25D366;font-size:1.4rem;font-weight:900;margin-bottom:4px;text-shadow:0 0 20px rgba(37,211,102,0.5);">اضغط هنا</span>
    <span style="color:#25D366;font-size:2.4rem;line-height:1;font-weight:900;">↓</span>
  </div>
  <a href="https://wa.me/+201500002822" target="_blank" style="display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;padding:12px 28px;border-radius:50px;font-size:0.9rem;font-weight:700;text-decoration:none;">💬 تواصل على واتساب</a>
</div>
<style>
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(6px)}}
</style>
  </div>
</div>
<div id="main-content">
<div class="hero">
  <div class="hero-overlay"></div>
