<script>
// ══ الباقات من Firebase ══
const PACKAGES = {orange:[],vodafone:[],vodafone_business:[],we:[],etisalat:[]};
let packagesLoaded = false;

const NET_CONDITIONS = {
  orange: {
    title: '🟠 شروط أورنج',
    items: [
      {text: 'لو سالف عادي — مفيش مشكلة', type: 'ok'},
      {text: 'التفعيل بالرقم بس — مش بيبعت كود', type: 'ok'},
      {text: 'الخط لازم ما يكونش فاتورة', type: 'warn'},
      {text: 'نظام الخط بيفضل زي ما هو — مش بيتغير', type: 'info'},
    ]
  },
  vodafone: {
    title: '🔴 شروط فودافون أفراد',
    items: [
      {text: 'متكونش سالف على الخط', type: 'warn'},
      {text: 'يفضل يكون فيه 2 جنيه رصيد على الأقل', type: 'info'},
      {text: 'لو أول مرة — التفعيل بيكون خلال نفس اليوم', type: 'info'},
      {text: 'فاتورة كل 3 شهور — 23 جنيه رسوم من الشركة', type: 'warn'},
    ]
  },
  vodafone_business: {
    title: '💼 شروط فودافون بيزنس',
    items: [
      {text: 'متكونش سالف على الخط', type: 'warn'},
      {text: 'يفضل يكون فيه 2 جنيه رصيد على الأقل', type: 'info'},
      {text: 'لو أول مرة — التفعيل بيكون خلال نفس اليوم', type: 'info'},
      {text: 'مطلوب صورة البطاقة وش وضهر واضحة', type: 'warn'},
      {text: 'الالتزام بالتجديد لمدة لا تقل عن 6 شهور', type: 'warn'},
      {text: 'في حالة عدم التجديد بعد الـ6 شهور — بتبلغني قبل التجديد بـ4 أيام وببعتلك تنازل مع شركة شحن بتروح بيه الفرع ترجع الخط كما كان', type: 'info'},
    ]
  },
  we: {
    title: '🟣 شروط وى',
    items: [
      {text: 'لو سالف عادي — مفيش مشكلة', type: 'ok'},
      {text: 'التفعيل بالرقم بس — مش بيبعت كود', type: 'ok'},
      {text: 'الخط لازم ما يكونش فاتورة', type: 'warn'},
      {text: 'الخط لازم ما يكونش تكافل وكرامة', type: 'warn'},
      {text: 'نظام الخط بيفضل زي ما هو — مش بيتغير', type: 'info'},
    ]
  },
  etisalat: {
    title: '🟢 شروط اتصالات',
    items: [
      {text: 'لازم تكون على نظام 15 قرش', type: 'warn'},
      {text: 'متكونش سالف على الخط', type: 'warn'},
      {text: 'الخط بيكون على نظام الفاتورة إيمرالد العيلة — رسوم النظام الشهرية 14 جنيه', type: 'info'},
    ]
  }
};
function showCond(net){
  const c = NET_CONDITIONS[net];
  if(!c) return;
  document.getElementById('cond-title').textContent = c.title;
  document.getElementById('cond-list').innerHTML = c.items.map(function(i){
    var cls = i.type==='warn'?'warn':i.type==='info'?'info':'';
    return '<li class="'+cls+'">'+i.text+'</li>';
  }).join('');
  document.getElementById('cond-modal').classList.add('show');
}
function hideCond(){ document.getElementById('cond-modal').classList.remove('show'); }
const NET_NAMES={orange:'أورنج 🟠',vodafone:'فودافون أفراد 🔴',vodafone_business:'فودافون بيزنس 💼',we:'وى 🟣',etisalat:'اتصالات 🟢'};
const NET_COLORS={orange:['#FF6B00','255,107,0','#FFD700'],vodafone:['#E3000F','227,0,15','#FF6B00'],vodafone_business:['#C8000A','200,0,10','#8B0000'],we:['#9B27AF','155,39,175','#E040FB'],etisalat:['#00A550','0,165,80','#7ED957']};
const PAY_LABELS={wallet:'محفظة إلكترونية 📲',instapay:'إنستا باي 💜'};
let state={network:'',pkg:null,payMethod:'',fromPhone:'',receiptData:null,name:'',phone:'',notes:''};

async function selectNetwork(net){
  state.network=net;state.pkg=null;
  if(!packagesLoaded){
    document.getElementById('pkgs-section').style.display='block';
    document.getElementById('pkgs-grid').innerHTML='<div class="no-pkgs"><div class="no-pkgs-icon">⏳</div><div class="no-pkgs-title">جاري تحميل الباقات...</div></div>';
    await loadPackagesFromFirebase();
  }
  const colorMap={orange:'orange-card',vodafone:'vodafone-card',vodafone_business:'vfbiz-card',we:'we-card',etisalat:'etisalat-card'};
  document.querySelectorAll('.net-card').forEach(c=>{
    const orig=Object.values(colorMap).find(cls=>c.classList.contains(cls));
    c.className='net-card'+(orig?' '+orig:'');
  });
  const card=document.getElementById('net-'+net);
  if(card) card.classList.add('selected-'+net);
  renderPackages(net);
  document.getElementById('pkgs-section').style.display='block';
  document.getElementById('pane1-nav').style.display='none';
  // سكرول ناعم لأول باقة
  setTimeout(function(){
    var sec=document.getElementById('pkgs-section');
    if(sec){sec.scrollIntoView({behavior:'smooth',block:'start'});}
  },100);
}
function renderPackages(net){
  const[c1,rgb,c2]=NET_COLORS[net];
  // ترتيب الباقات من الأصغر للأكبر جيجا
  const list=(PACKAGES[net]||[]).slice().sort(function(a,b){
    var ga=parseFloat(a.gb)||0;var gb=parseFloat(b.gb)||0;return ga-gb;
  });
  const grid=document.getElementById('pkgs-grid');
  if(!list.length){grid.innerHTML='<div class="no-pkgs"><div class="no-pkgs-icon">📭</div><div class="no-pkgs-title">لا يوجد باقات في الوقت الحالي</div><div class="no-pkgs-sub">يرجى التواصل معنا للاستفسار عن الباقات المتاحة</div><a href="https://wa.me/+201500002822" target="_blank" style="display:inline-flex;align-items:center;gap:6px;margin-top:12px;background:#25D366;color:#fff;padding:9px 20px;border-radius:50px;font-size:0.82rem;font-weight:700;text-decoration:none;">💬 تواصل معنا على واتساب</a></div>';return;}
  grid.innerHTML=list.map(function(p){
    var hasVal=function(v){return v!==undefined&&v!==null&&v!==''&&Number(v)!==0;};
    var isEtisalat=(net==='etisalat');
    var details='';
    if(p.walletNumber) details+='<div class="pkg-info-row"><span class="pkg-info-lbl">📲 رقم المحفظة</span></div><div class="pkg-info-val" style="color:'+c1+';">'+p.walletNumber+'</div>';
    if(p.instapayNumber) details+='<div class="pkg-info-row" style="margin-top:8px;"><span class="pkg-info-lbl">💜 رقم إنستا باي</span></div><div class="pkg-info-val" style="color:#6366F1;">'+p.instapayNumber+'</div>';
    if(p.startDate||p.endDate){
      details+='<div class="pkg-info-row" style="margin-top:8px;"><span class="pkg-info-lbl">📅 الفترة</span></div>';
      if(p.startDate) details+='<div class="pkg-info-val">من &nbsp;'+p.startDate+'</div>';
      if(p.endDate) details+='<div class="pkg-info-val">إلى &nbsp;'+p.endDate+'</div>';
    }

    // layout اتصالات: صفين — صف١: جيجا+دقايق، صف٢: رسايل+دولية، ثم السعر
    var statsHtml='';
    if(isEtisalat){
      var row1='';var row2='';
      if(hasVal(p.gb))   row1+='<div class="pkg-stat"><div class="pkg-stat-val">'+p.gb+'</div><div class="pkg-stat-lbl">📶 جيجا</div></div>';
      if(hasVal(p.minutes)) row1+=(row1?'<div class="pkg-divider"></div>':'')+'<div class="pkg-stat"><div class="pkg-stat-val" style="color:#1A1A2E;">'+p.minutes+'</div><div class="pkg-stat-lbl">📞 دقيقة</div></div>';
      if(hasVal(p.sms))  row2+='<div class="pkg-stat"><div class="pkg-stat-val" style="color:#6366F1;">'+p.sms+'</div><div class="pkg-stat-lbl">✉️ رسالة</div></div>';
      if(hasVal(p.intlMins)) row2+=(row2?'<div class="pkg-divider"></div>':'')+'<div class="pkg-stat"><div class="pkg-stat-val" style="color:#10B981;">'+p.intlMins+'</div><div class="pkg-stat-lbl">🌍 د.دولية</div></div>';
      statsHtml=(row1?'<div class="pkg-main-row">'+row1+'</div>':'')+(row2?'<div class="pkg-main-row" style="border-top:1px solid #F3F4F6;padding-top:10px;">'+row2+'</div>':'');
    } else {
      var hm=hasVal(p.minutes);
      statsHtml='<div class="pkg-main-row">'
        +(hasVal(p.gb)?'<div class="pkg-stat"><div class="pkg-stat-val">'+p.gb+'</div><div class="pkg-stat-lbl">جيجا</div></div>':'')
        +(hm?'<div class="pkg-divider"></div><div class="pkg-stat"><div class="pkg-stat-val" style="color:#1A1A2E;">'+p.minutes+'</div><div class="pkg-stat-lbl">دقيقة</div></div>':'')
        +(hasVal(p.sms)?'<div class="pkg-divider"></div><div class="pkg-stat"><div class="pkg-stat-val" style="font-size:1.4rem;color:#6366F1;">'+p.sms+'</div><div class="pkg-stat-lbl">✉️ رسالة</div></div>':'')
        +(hasVal(p.intlMins)?'<div class="pkg-divider"></div><div class="pkg-stat"><div class="pkg-stat-val" style="font-size:1.4rem;color:#10B981;">'+p.intlMins+'</div><div class="pkg-stat-lbl">🌍 د.دولية</div></div>':'')
        +'</div>';
    }

    return '<div class="pkg-card" id="pk-'+p.id+'" data-pkgid="'+p.id+'" style="--accent:'+c1+';--accent-rgb:'+rgb+';--accent2:'+c2+';">'
      +(p.popular?'<div class="pkg-badge">🔥 الأكثر طلباً</div>':'')
      +'<div class="pkg-check">✓</div>'
      +'<div class="pkg-header"><div class="pkg-name-title">'+p.name+'</div></div>'
      +statsHtml
      +'<div class="pkg-price-row"><div class="pkg-price">'+p.price+' جنيه</div><div class="pkg-price-lbl">شهرياً</div></div>'
      +(details?'<div class="pkg-info-block">'+details+'</div>':'')
      +(p.note?'<div class="pkg-note"><span class="pkg-note-icon">💡</span><span>'+p.note+'</span></div>':'')
      +'</div>';
  }).join('');
}
document.getElementById('pkgs-grid').addEventListener('click',function(e){const card=e.target.closest('.pkg-card[data-pkgid]');if(!card)return;selectPkg(card.dataset.pkgid);});
function selectPkg(id){const net=state.network;const p=PACKAGES[net]?.find(x=>x.id===id);if(!p)return;state.pkg=p;document.querySelectorAll('.pkg-card').forEach(c=>c.classList.remove('selected'));const el=document.getElementById('pk-'+id);if(el)el.classList.add('selected');document.getElementById('pane1-nav').style.display='flex';updatePayNumbers(p);}
function updatePayNumbers(p){const wb=document.getElementById('wallet-num-box');const wh=document.getElementById('wallet-copy-hint');if(p.walletNumber){document.getElementById('wallet-num-text').textContent=p.walletNumber;wb.classList.add('visible');wh.style.display='block';}else{wb.classList.remove('visible');wh.style.display='none';}const ib=document.getElementById('instapay-num-box');const ih=document.getElementById('instapay-copy-hint');if(p.instapayNumber){document.getElementById('instapay-num-text').textContent=p.instapayNumber;ib.classList.add('visible');ih.style.display='block';}else{ib.classList.remove('visible');ih.style.display='none';}}
function selectPay(method){state.payMethod=method;document.querySelectorAll('.pay-card').forEach(c=>c.classList.remove('selected'));document.getElementById('pay-'+method).classList.add('selected');document.getElementById('transfer-section').style.display='block';}
function copyNum(e,type){e.stopPropagation();const n=document.getElementById(type+'-num-text')?.textContent?.trim();if(!n)return;navigator.clipboard.writeText(n).then(()=>toast('✅ تم نسخ الرقم: '+n,'ok')).catch(()=>{const t=document.createElement('textarea');t.value=n;t.style.position='fixed';t.style.opacity='0';document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);toast('✅ تم نسخ الرقم: '+n,'ok');});}
function handleFile(file){if(!file)return;const r=new FileReader();r.onload=e=>{state.receiptData=e.target.result;document.getElementById('preview-img').src=e.target.result;document.getElementById('upload-preview').style.display='block';document.getElementById('upload-area').querySelector('.upload-lbl').textContent='✅ تم رفع الصورة';};r.readAsDataURL(file);}
function handleDrop(e){e.preventDefault();document.getElementById('upload-area').classList.remove('drag');handleFile(e.dataTransfer.files[0]);}
function showPane(n){document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));document.getElementById('pane'+n).classList.add('active');document.querySelectorAll('.step').forEach((s,i)=>{s.classList.remove('active','done');if(i+1===n)s.classList.add('active');else if(i+1<n)s.classList.add('done');});window.scrollTo({top:0,behavior:'smooth'});}
function goStep2(){if(!state.network)return toast('اختار الشبكة الأول','err');if(!state.pkg)return toast('اختار الباقة الأول','err');showPane(2);}
function goStep3(){if(!state.payMethod)return toast('اختار طريقة الدفع','err');const ph=document.getElementById('from-phone').value.trim();if(!ph)return toast('ادخل رقم الموبايل اللي حولت منه','err');if(ph.length<10)return toast('رقم التليفون غلط','err');if(!state.receiptData)return toast('ارفع صورة إيصال التحويل','err');state.fromPhone=ph;showPane(3);}
function goStep4(){state.name=document.getElementById('cust-name').value.trim();state.phone=document.getElementById('cust-phone').value.trim();state.notes=document.getElementById('cust-notes').value.trim();if(!state.name)return toast('ادخل اسمك','err');if(!state.phone||state.phone.length<10)return toast('ادخل رقم موبايلك صح','err');document.getElementById('sum-net').textContent=NET_NAMES[state.network]||'—';document.getElementById('sum-pkg').textContent=state.pkg?.name||'—';document.getElementById('sum-gb').textContent=(state.pkg?.gb||'—')+' جيجا';document.getElementById('sum-mins').textContent=state.pkg?.minutes&&state.pkg.minutes!=='0'?state.pkg.minutes+' دقيقة':'—';document.getElementById('sum-pay').textContent=PAY_LABELS[state.payMethod]||state.payMethod;document.getElementById('sum-fromphn').textContent=state.fromPhone||'—';document.getElementById('sum-name').textContent=state.name;document.getElementById('sum-phone').textContent=state.phone;document.getElementById('sum-price').textContent=(state.pkg?.price||0)+' جنيه';showPane(4);}
function submitOrder(){
  const btn=document.getElementById('submit-btn');
  btn.disabled=true;btn.textContent='⏳ جاري الإرسال...';
  const orderId='ORD-'+Date.now().toString().slice(-6);
  const orderData={id:orderId,createdAt:new Date().toISOString(),network:state.network,networkName:NET_NAMES[state.network],pkgId:state.pkg?.id,pkgName:state.pkg?.name,gb:state.pkg?.gb,minutes:state.pkg?.minutes,price:state.pkg?.price,payMethod:state.payMethod,payMethodName:PAY_LABELS[state.payMethod],fromPhone:state.fromPhone,customerName:state.name,customerPhone:state.phone,notes:state.notes,status:'pending'};
  function showSuccess(){
    document.getElementById('order-id-display').textContent='#'+orderId;
    document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));
    document.getElementById('success-screen').classList.add('show');
    window.scrollTo({top:0,behavior:'smooth'});
  }
  function saveOrder(receiptUrl){
    orderData.receipt = receiptUrl||'';
    if(window._db&&window._addDoc){
      window._addDoc(window._col('orders'),orderData).then(showSuccess).catch(()=>{btn.disabled=false;btn.textContent='✅ تأكيد الطلب';alert('حدث خطأ، حاول تاني');});
    } else { setTimeout(showSuccess,1200); }
  }
  if(state.receiptData){
    btn.textContent='⏳ جاري رفع الإيصال...';
    const formData = new FormData();
    formData.append('file', state.receiptData);
    formData.append('upload_preset', 'ibrahim_orders');
    formData.append('cloud_name', 'dka6v6ihp');
    fetch('https://api.cloudinary.com/v1_1/dka6v6ihp/image/upload', {method:'POST',body:formData})
      .then(r=>r.json())
      .then(data=>saveOrder(data.secure_url||''))
      .catch(()=>saveOrder(''));
  } else { saveOrder(''); }
}
function resetForm(){state={network:'',pkg:null,payMethod:'',fromPhone:'',receiptData:null,name:'',phone:'',notes:''};document.getElementById('success-screen').classList.remove('show');document.querySelectorAll('.net-card').forEach(c=>c.className='net-card');document.getElementById('pkgs-section').style.display='none';document.getElementById('pane1-nav').style.display='none';document.getElementById('transfer-section').style.display='none';document.getElementById('upload-preview').style.display='none';['from-phone','cust-name','cust-phone','cust-notes'].forEach(id=>document.getElementById(id).value='');document.querySelectorAll('.pay-card').forEach(c=>c.classList.remove('selected'));document.getElementById('submit-btn').disabled=false;document.getElementById('submit-btn').textContent='✅ تأكيد الطلب';showPane(1);}
document.getElementById('from-phone').addEventListener('input',e=>state.fromPhone=e.target.value.trim());
function openInstapayLink(e){
  e.preventDefault();
  e.stopPropagation();
  const link = window._instapayLink;
  if(!link) return;
  window.open(link, '_blank');
}
function toast(msg,type='ok'){const t=document.getElementById('toast');t.textContent=msg;t.className='toast '+type+' show';setTimeout(()=>t.classList.remove('show'),3000);}
</script>
</body>
</html>
